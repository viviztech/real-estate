// Prisma Schema for Landliya Property Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== USER MANAGEMENT ==============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  phone         String?   @unique
  avatar        String?
  role          UserRole @default(USER)
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  properties    Property[]
  favorites     Favorite[]
  inquiries     Inquiry[] @relation("UserInquiries")
  ownedInquiries Inquiry[] @relation("OwnerInquiries")

  @@map("users")
}

enum UserRole {
  USER
  AGENT
  ADMIN
}

// ============== PROPERTIES ==============

model Property {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  description   String?       @db.Text
  
  // AI Generated
  aiDescription String?       @map("ai_description") @db.Text
  seoTitle      String?       @map("seo_title")
  seoDescription String?      @map("seo_description")
  
  // Property Details
  propertyType  PropertyType  @map("property_type")
  listingType   ListingType   @map("listing_type")
  status        PropertyStatus @default(ACTIVE)
  
  // Pricing
  price         Decimal       @db.Decimal(12, 2)
  pricePerSqft  Decimal?      @map("price_per_sqft") @db.Decimal(10, 2)
  
  // Location
  address       String
  locality      String
  city          String        @default("Pondicherry")
  state         String        @default("Tamil Nadu")
  pincode       String?
  latitude      Float?
  longitude     Float?
  
  // Features
  bedrooms       Int
  bathrooms      Int          @default(1)
  floor          Int?
  totalFloors    Int?         @map("total_floors")
  area          Float
  areaUnit      String       @default("sqft") @map("area_unit")
  
  // Additional
  yearBuilt     Int?         @map("year_built")
  facing        String?
  amenities     String[]
  images        String[]
  videoUrl      String?      @map("video_url")
  virtualTour   String?      @map("virtual_tour")
  
  // SEO
  metaTitle     String?      @map("meta_title")
  metaDescription String?    @map("meta_description")
  schemaMarkup  String?      @map("schema_markup")
  
  // Timestamps
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  publishedAt   DateTime?    @map("published_at")
  
  // Relations
  userId        String       @map("user_id")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  inquiries     Inquiry[]
  favorites     Favorite[]

  @@index([userId])
  @@index([propertyType])
  @@index([listingType])
  @@index([status])
  @@index([locality])
  @@index([price])
  @@index([bedrooms])
  @@index([createdAt])
  @@map("properties")
}

enum PropertyType {
  APARTMENT
  VILLA
  HOUSE
  FLAT
  PENTHOUSE
  BUNGALOW
  STUDIO
  LAND
}

enum ListingType {
  SALE
  RENT
  LEASE
}

enum PropertyStatus {
  DRAFT
  PENDING
  ACTIVE
  SOLD
  EXPIRED
}

// ============== FAVORITES ==============

model Favorite {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@map("favorites")
}

// ============== INQUIRIES ==============

model Inquiry {
  id          String        @id @default(cuid())
  message     String        @db.Text
  status      InquiryStatus @default(NEW)
  
  // Contact info (for guests)
  guestName   String?       @map("guest_name")
  guestEmail  String?       @map("guest_email")
  guestPhone  String?       @map("guest_phone")
  
  // Timestamps
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  respondedAt DateTime?     @map("responded_at")
  
  // Relations
  propertyId  String        @map("property_id")
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId      String?       @map("user_id")
  user        User?         @relation("UserInquiries", fields: [userId], references: [id], onDelete: SetNull)
  ownerId     String        @map("owner_id")
  owner       User          @relation("OwnerInquiries", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([ownerId])
  @@index([status])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
  CONVERTED
  CLOSED
}

// ============== LOCALITIES (SEO PAGES) ==============

model Locality {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  
  // SEO
  metaTitle   String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  
  // Stats
  avgPrice    Decimal? @map("avg_price") @db.Decimal(12, 2)
  propertyCount Int    @default(0) @map("property_count")
  
  // Location
  latitude    Float?
  longitude   Float?
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("localities")
}

// ============== BLOG/CONTENT ==============

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  content       String    @db.Text
  excerpt       String?   @db.Text
  featuredImage String?   @map("featured_image")
  
  // SEO
  metaTitle     String?   @map("meta_title")
  metaDescription String? @map("meta_description")
  schemaMarkup  String?   @map("schema_markup")
  
  // Status
  status        BlogStatus @default(DRAFT)
  publishedAt   DateTime?  @map("published_at")
  
  // Stats
  views         Int        @default(0)
  
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("blog_posts")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============== SETTINGS ==============

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
